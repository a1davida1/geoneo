# Search API keys (configure at least one for real market results)
# Option 1: Brave Search (free tier: 2000 searches/month)
# Sign up: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Option 2: SerpAPI (paid, best quality with local pack data)
# Sign up: https://serpapi.com/
SERP_API_KEY=

# Option 3: DataForSEO (paid, pay-per-use)
# Sign up: https://dataforseo.com/
SERP_API_LOGIN=
SERP_API_KEY=

# Optional — Google PageSpeed Insights for Core Web Vitals snapshot
PAGESPEED_API_KEY=

# Optional — Ahrefs API for backlink + authority enrichment in Prospect Hunter
# (paid API units consumed only when explicitly enabled per run)
# Sign up / dashboard: https://ahrefs.com/api
AHREFS_API_KEY=

# Optional — Resend transactional email for weekly score reports
# Without it, outbox messages fall back to data/email-outbox.json
RESEND_API_KEY=
RESEND_FROM=

# Optional — internal API auth for non-loopback admin access
# Set this to a strong random string and supply it as Bearer token from remote
GEONEO_INTERNAL_API_SECRET=

# Optional — alternate file paths (multi-tenant / tests)
# GEONEO_AUDITS_PATH=
# GEONEO_PROSPECTS_PATH=
# GEONEO_COMPETITORS_PATH=
# GEONEO_FIX_TRACKER_PATH=
# GEONEO_EMAIL_OUTBOX_PATH=

# Optional — same-origin limited crawl during website audits (BFS, static HTML fetch only)
# GEONEO_SITE_CRAWL_ENABLED=true
# GEONEO_SITE_CRAWL_MAX_PAGES=30
# GEONEO_SITE_CRAWL_MAX_DEPTH=3
# GEONEO_SITE_CRAWL_BUDGET_MS=45000
# GEONEO_SITE_CRAWL_PER_FETCH_MS=12000

# Optional — server runtime
ALLOW_INSECURE_FETCH=0
# LISTEN ON ALL INTERFACES (phone / LAN hitting server by IP). Default is localhost-only in dev.
# HOST=0.0.0.0
# TZ=America/Chicago  # ensures weekly cron fires at Ozarks 03:00, not server local

# Optional — local Postgres (docker compose up -d in this directory)
# Connection string matches geoneo-ai/docker-compose.yml defaults.
# DATABASE_URL=postgresql://geoneo:geoneo_local@127.0.0.1:5432/geoneo
# Supabase free tier is fine for small apps (dashboard + auth + realtime extras) but has DB size /
# connection limits and is hosted; use local Docker when you want a plain Postgres with no vendor caps.
# Admin HTML: if you open admin from file:// or another origin, set in browser localStorage:
#   geoneo_api_base = http://127.0.0.1:4173   (no trailing slash; match your PORT)
